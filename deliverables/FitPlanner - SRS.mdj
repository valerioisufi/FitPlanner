							"lineStyle": 3,
							"points": "3287:647;3062:653",
							"showVisibility": true,
							"nameLabel": {
								"$ref": "AAAAAAGdmxRhdWjejww="
							},
							"stereotypeLabel": {
								"$ref": "AAAAAAGdmxRhdWjf7Ek="
